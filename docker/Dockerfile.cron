FROM alpine:3.20

RUN apk add --no-cache \
        bash curl postgresql16-client restic gzip \
    && mkdir -p /scripts /var/log

COPY scripts/backup.sh /scripts/backup.sh
RUN chmod +x /scripts/backup.sh

RUN echo "0 3 * * * /scripts/backup.sh >> /var/log/backup.log 2>&1" \
        > /etc/crontabs/root \
    && touch /var/log/backup.log

CMD ["sh", "-c", "crond -f -d 8 & tail -F /var/log/backup.log"]
